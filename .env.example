# ─────────────────────────────────────────────────────────────
# Watchlist + growth-history feature
# Copy to .env.local for local dev, and set the same vars on Vercel.
# ─────────────────────────────────────────────────────────────

# Supabase project URL. Safe to expose (used as the API endpoint).
# Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://<your-project-ref>.supabase.co"

# Supabase SERVICE ROLE key — SECRET, server-side only (cron + server actions).
# It bypasses Row-Level Security, so never expose it to the browser / commit the real value.
# Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"

# Secret protecting the snapshot cron endpoint (/api/cron/snapshot).
# Vercel Cron automatically sends `Authorization: Bearer $CRON_SECRET`;
# the route returns 401 for anything else. Generate a long random string,
# e.g.  openssl rand -hex 32
CRON_SECRET="<a-long-random-string>"

# Comma-separated list of emails allowed into the /admin dashboard.
ADMIN_EMAILS="admin@example.com"
